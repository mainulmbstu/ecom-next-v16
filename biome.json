{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
     "rules": {
      "recommended": true,
      "correctness": {
        "noUndeclaredVariables": "error",
        "noUndeclaredDependencies": "error"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noUnassignedVariables": "info"
      },
      "a11y": {
        "useButtonType": "info"
      },
        "style": {
        "useConst": "off"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
    "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
